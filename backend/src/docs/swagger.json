{
  "openapi": "3.0.3",
  "info": {
    "title": "Flora API",
    "description": "REST API for the Flora bouquets catalog",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api"
    }
  ],
  "paths": {
    "/bouquets": {
      "get": {
        "summary": "Get all bouquets",
        "tags": ["Bouquets"],
        "responses": {
          "200": {
            "description": "List of bouquets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Bouquet" }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a bouquet",
        "tags": ["Bouquets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BouquetCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created bouquet",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Bouquet" }
              }
            }
          },
          "400": { "description": "Validation error" }
        }
      }
    },
    "/bouquets/{id}": {
      "get": {
        "summary": "Get a bouquet by id",
        "tags": ["Bouquets"],
        "parameters": [{ "$ref": "#/components/parameters/BouquetId" }],
        "responses": {
          "200": {
            "description": "Bouquet found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Bouquet" }
              }
            }
          },
          "404": { "description": "Not found" }
        }
      },
      "put": {
        "summary": "Update a bouquet by id",
        "tags": ["Bouquets"],
        "parameters": [{ "$ref": "#/components/parameters/BouquetId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BouquetUpdate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated bouquet",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Bouquet" }
              }
            }
          },
          "400": { "description": "Empty or invalid body" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "summary": "Delete a bouquet by id",
        "tags": ["Bouquets"],
        "parameters": [{ "$ref": "#/components/parameters/BouquetId" }],
        "responses": {
          "200": {
            "description": "Deleted bouquet",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Bouquet" }
              }
            }
          },
          "404": { "description": "Not found" }
        }
      }
    },
    "/bouquets/{id}/favorite": {
      "patch": {
        "summary": "Update the favorite status of a bouquet",
        "tags": ["Bouquets"],
        "parameters": [{ "$ref": "#/components/parameters/BouquetId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["favorite"],
                "properties": {
                  "favorite": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated bouquet",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Bouquet" }
              }
            }
          },
          "400": { "description": "Validation error" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/bouquets/{id}/photo": {
      "patch": {
        "summary": "Upload/replace the photo of a bouquet",
        "tags": ["Bouquets"],
        "parameters": [{ "$ref": "#/components/parameters/BouquetId" }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["photo"],
                "properties": {
                  "photo": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New photo URL",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "photoURL": { "type": "string", "format": "uri" }
                  }
                }
              }
            }
          },
          "400": { "description": "Missing or invalid file" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/orders": {
      "post": {
        "summary": "Create an order for a bouquet",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OrderCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created order",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Order" }
              }
            }
          },
          "400": { "description": "Validation error" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "BouquetId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      }
    },
    "schemas": {
      "Bouquet": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "title": { "type": "string", "example": "Spring Elegance" },
          "description": {
            "type": "string",
            "example": "A fresh bouquet of seasonal blooms."
          },
          "price": { "type": "number", "example": 35 },
          "photoURL": {
            "type": "string",
            "format": "uri",
            "example": "https://flora-backend.onrender.com/public/photos/spring-elegance.png"
          },
          "favorite": { "type": "boolean", "example": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "BouquetCreate": {
        "type": "object",
        "required": ["title", "description", "price"],
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "number" },
          "photoURL": { "type": "string", "format": "uri" },
          "favorite": { "type": "boolean" }
        }
      },
      "BouquetUpdate": {
        "type": "object",
        "minProperties": 1,
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "number" },
          "photoURL": { "type": "string", "format": "uri" },
          "favorite": { "type": "boolean" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "phone": { "type": "string" },
          "address": { "type": "string" },
          "message": { "type": "string" },
          "bouquetId": { "type": "integer" },
          "quantity": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "OrderCreate": {
        "type": "object",
        "required": ["name", "phone", "address", "bouquetId", "quantity"],
        "properties": {
          "name": { "type": "string" },
          "phone": { "type": "string" },
          "address": { "type": "string" },
          "message": { "type": "string" },
          "bouquetId": { "type": "integer" },
          "quantity": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
