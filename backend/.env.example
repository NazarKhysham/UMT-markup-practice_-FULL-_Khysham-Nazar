PORT=3000

# Full connection string for the cloud PostgreSQL instance (e.g. from Render)
DATABASE_URL=postgres://user:password@host:5432/database

# Set to "false" to disable SSL for a local Postgres instance without SSL support
DB_SSL=true

# Public base URL of this backend, used to build absolute photoURL values in API responses
BACKEND_URL=http://localhost:3000

# Comma-separated list of origins allowed to call this API
CORS_ORIGIN=http://localhost:4500,https://nazarkhysham.github.io
